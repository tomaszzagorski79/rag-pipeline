# Qdrant Cloud
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# Jina AI (embeddingi + reader)
JINA_API_KEY=your_jina_api_key

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google AI (opcjonalne — benchmarki embeddingów Gemini)
GOOGLE_API_KEY=

# Neo4j (opcjonalne — Graph RAG / Hybrid Vector+Graph / Context Engineering)
# Utwórz darmową instancję: https://console.neo4j.io/
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
